{
  "$schema": "https://opencode.ai/config.json",
  "model": "{env:HARNESS_MODEL}",
  "small_model": "{env:HARNESS_MODEL}",
  "provider": {
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    },
    "minimax-global-openai": {
      "name": "MiniMax Global (OpenAI-compatible)",
      "env": [
        "MINIMAX_API_KEY"
      ],
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:MINIMAX_API_KEY}",
        "baseURL": "https://api.minimax.io/v1"
      },
      "models": {
        "MiniMax-M3": {
          "id": "MiniMax-M3",
          "name": "MiniMax-M3",
          "attachment": true,
          "reasoning": true,
          "limit": {
            "context": 1000000,
            "output": 524288
          },
          "cost": {
            "input": 0.3,
            "output": 1.2,
            "cache_read": 0.06
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "video"
            ],
            "output": [
              "text"
            ]
          }
        },
        "MiniMax-M2.7": {
          "id": "MiniMax-M2.7",
          "name": "MiniMax-M2.7",
          "attachment": false,
          "reasoning": true,
          "limit": {
            "context": 204800,
            "output": 204800
          },
          "cost": {
            "input": 0.3,
            "output": 1.2,
            "cache_read": 0.06,
            "cache_write": 0.375
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "minimax-cn-openai": {
      "name": "MiniMax China (OpenAI-compatible)",
      "env": [
        "MINIMAX_API_KEY"
      ],
