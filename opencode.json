          },
          "cost": {
            "input": 0.3,
            "output": 1.2,
            "cache_read": 0.06,
            "cache_write": 0.375
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "minimax-anthropic": {
      "name": "MiniMax (Anthropic-compatible)",
      "env": [
        "MINIMAX_API_KEY"
      ],
      "npm": "@ai-sdk/anthropic",
      "options": {
        "apiKey": "{env:MINIMAX_API_KEY}",
        "baseURL": "{env:ANTHROPIC_BASE_URL}/v1"
      },
      "models": {
        "MiniMax-M3": {
          "id": "MiniMax-M3",
